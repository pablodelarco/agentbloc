# AgentBloc v2.5 environment template
#
# Copy to .env (gitignored) and fill in values.
#   cp .env.example .env
#
# .env is sourced by:
#   - scripts/wake.sh        (every cron tick, before claude-wrap)
#   - scripts/install-demo.sh (one-time, at install)
#   - scripts/loop.sh        (foreground substitute for cron)
#   - scripts/telegram-*.sh  (sends/polls)
#
# All values below are OPTIONAL except where flagged REQUIRED. Defaults
# match the MOCK demo path so a fresh clone can run end-to-end without
# any external accounts.

# ─── Demo mode ───────────────────────────────────────────────────────────────
# mock = no Telegram bot needed; sends route to telegram-out.jsonl
# real = curl real Telegram Bot API; requires TELEGRAM_BOT_TOKEN below
AGENTBLOC_DEMO=mock

# When AGENTBLOC_DEMO=mock, install-demo.sh exports TELEGRAM_MOCK=1 for
# you. You can also set it directly here to override per-shell.
# TELEGRAM_MOCK=1

# ─── Anthropic credentials ──────────────────────────────────────────────────
# REQUIRED for claude-wrap.sh to succeed (it forwards stdin to `claude -p`).
# If you use OAuth keychain auth in your shell, you can leave this blank
# AND set CLAUDE_WRAP_BARE=0 (default) so claude reads your keychain.
# For cron-driven wakes on a server with no GUI, set the API key here.
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Telegram (real mode only) ───────────────────────────────────────────────
# Get a bot token from @BotFather on Telegram (free, ~30 seconds).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Scheduling fallback ─────────────────────────────────────────────────────
# Set to 1 to skip crontab installation. install-demo.sh prints
# instructions for `./scripts/loop.sh` instead. Use this on:
#   - macOS Sonoma+ without Full Disk Access granted (AB-008)
#   - NixOS / immutable distros
#   - corporate machines that block `crontab -`
# AGENTBLOC_NO_CRON=1

# ─── claude-wrap tunables ────────────────────────────────────────────────────
# Per-invocation hard timeout, in seconds. Above this, the wrapper kills
# the claude process and logs a 124 exit. Conservative default keeps
# stuck runs from blocking the next cron tick.
CLAUDE_WRAP_TIMEOUT_SEC=120

# Per-invocation cost ceiling (USD). claude itself enforces this via
# --max-budget-usd. Cron interval is the soft ceiling; this is the hard
# ceiling. 0.50 covers ~30k input + 5k output tokens on Sonnet.
CLAUDE_WRAP_MAX_BUDGET_USD=0.50

# Set to 1 to pass --bare to claude (skips hooks/LSP/auto-memory). Faster
# wake-job execution but requires ANTHROPIC_API_KEY (no OAuth keychain).
CLAUDE_WRAP_BARE=0

# ─── Inbox janitor tunables ──────────────────────────────────────────────────
# Minutes before .<id>.tmp files in inbox/ are reclaimed (writer crashed
# mid-write). Higher = more tolerant of slow filesystems; lower = faster
# recovery from writer crashes.
INBOX_TMP_STALE_MIN=10

# Minutes before inbox/processing/ entries are reclaimed (reader crashed
# mid-processing). Reclaimed entries move back to inbox/ for re-claim.
# Should be > the longest expected wake duration.
INBOX_STALE_MIN=15

# inbox/processed/ entry count threshold. Above this, oldest 50% rotate
# to inbox/processed/<YYYY-MM>/ archives. Keeps `find` and `ls` snappy
# on long-running deployments.
INBOX_PROCESSED_MAX=1000

    "MD013": false,
    "MD033": false,
    "MD024": { "siblings_only": true },
    "MD041": false,
    "MD040": false,
    "MD060": false,
    "MD032": false,
    "MD022": false,
    "MD031": false,
    "MD058": false,
    "MD036": false,
    "MD012": false,
    "MD038": false,
    "MD007": false,
    "MD029": false,
    "MD055": false,
    "MD051": false,
    "MD034": false,
    "MD037": false
}
